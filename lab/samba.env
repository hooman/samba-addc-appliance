# Environment for running Samba AD DC appliance scenarios through
# ../lab-kit/bin/run-scenario.sh. Paths here are resolved relative to the
# current working directory at invocation time; run-scenario.sh (the wrapper
# in this directory) cd's into the Samba repo root before sourcing.

LAB_NAME=samba-addc
LAB_RESULTS_DIR=test-results

# Hyper-V target.
LAB_HV_HOST=server
LAB_HV_USER=nmadmin

# VM under test.
LAB_VM_NAME=samba-dc1
LAB_VM_IP=10.10.10.20
LAB_VM_USER=debadmin
LAB_GOLDEN_CHECKPOINT=golden-image

# Host share that Hyper-V helper scripts are run from.
# The stage step below refreshes it before each run.
# LAB_STAGE_DIR is the Mac-visible path; LAB_HOST_STAGE_DIR is the same
# share as seen from the Hyper-V host (used when invoking pwsh via ssh).
LAB_STAGE_DIR=/Volumes/ISO/lab-scripts
LAB_HOST_STAGE_DIR='D:\ISO\lab-scripts'

# Helper scripts from all three sibling repos. Revert-TestVM.ps1 comes from
# lab-kit; New-LabRouter.ps1 from lab-router; Samba-specific WS2025 and
# baseline helpers from this repo. Globs are expanded by the shell.
LAB_STAGE_SOURCES="lab/*.ps1 lab/*.xml ../lab-kit/hypervisors/hyperv/*.ps1 ../lab-router/hypervisors/hyperv/*.ps1"

# Appliance scripts scp'd to /tmp on samba-dc1 before each run.
LAB_PUSH_FILES="prepare-image.sh samba-sconfig.sh"
LAB_REMOTE_PUSH_DIR=/tmp

# After scp, install samba-sconfig so scenarios can invoke it directly.
LAB_POST_PUSH_CMD='sudo install -m 0755 /tmp/samba-sconfig.sh /usr/local/sbin/samba-sconfig'
