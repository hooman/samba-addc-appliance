        <mxCell id="t1" value="&lt;b&gt;T1 — Smoke&lt;/b&gt;&#10;&#10;revert golden-image → boot&#10;services disabled ✓&#10;samba-sconfig present ✓&#10;pwsh 7.6 ✓&#10;&#10;&lt;i&gt;note: chrony NTP pools&#10;unreachable on isolated net&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="50" y="590" width="230" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="&lt;b&gt;T2 — Join WS2025 as DC&lt;/b&gt;&#10;&#10;1st attempt:&#10;&lt;font color=&quot;#b85450&quot;&gt;WERR_DS_INCOMPATIBLE_VERSION&lt;/font&gt;&#10;(OS-FL 4 vs forest-FL 7)&#10;&#10;&lt;b&gt;Fix:&lt;/b&gt; --option=&amp;quot;ad dc&#10;functional level = 2016&amp;quot;&#10;&#10;2nd attempt: &lt;b&gt;joined ✓&lt;/b&gt;&#10;samba-ad-dc active, TGT OK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="300" y="590" width="230" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="&lt;b&gt;T3 — Replication + Functional&lt;/b&gt;&#10;&#10;inbound (WS→Samba): clean ✓&#10;outbound: &lt;font color=&quot;#b85450&quot;&gt;8524 DNS err&lt;/font&gt;&#10;&#10;&lt;b&gt;Fix:&lt;/b&gt; PTR 20 →&#10;samba-dc1.lab.test&#10;&#10;Users + GPO objects replicate ✓&#10;&lt;i&gt;SYSVOL: rsync fallback&#10;(Samba has no DFSR)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="550" y="590" width="230" height="200" as="geometry"/>
