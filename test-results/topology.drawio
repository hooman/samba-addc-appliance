<mxfile host="Electron" agent="Claude Code" type="device">
  <diagram id="samba-lab-v2" name="Samba AD Lab v2 — DHCP-NAT topology">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Samba AD DC Appliance — Lab v2 topology" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="5" width="500" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="mac" value="&lt;b&gt;Mac&lt;/b&gt; (Claude Code operator)&#10;~/.ssh/id_ed25519 → nmadmin@server&#10;                          → hm@10.10.10.1 (jump)&#10;                          → debadmin@10.10.10.20 (jump)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="470" y="40" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="internet" value="&lt;b&gt;Internet&lt;/b&gt;" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="host" value="Hyper-V Host — &#39;server&#39; (Windows Server 2025, PowerShell 7.6)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="1120" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="extsw" value="&lt;b&gt;PCI 1G Port 1&lt;/b&gt; (external switch)&#10;→ real network, DHCP + Internet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="65" y="190" width="300" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="router" value="&lt;b&gt;router1&lt;/b&gt; — Debian genericcloud + cloud-init&#10;&#10;WAN (eth0): DHCP from real network&#10;LAN (eth1): 10.10.10.1/24 static&#10;&#10;nftables: masquerade eth0 ← eth1&#10;dnsmasq:   DHCP pool 10.10.10.100-200&#10;            reservations (by MAC):&#10;              00:15:5D:0A:0A:0A → WS2025-DC1  (.10)&#10;              00:15:5D:0A:0A:14 → samba-dc1   (.20)&#10;            DNS forwarder to 1.1.1.1 / 8.8.8.8&#10;            delegates zone lab.test → .10 &amp; .20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=10;align=center;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="65" y="270" width="320" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="intsw" value="&lt;b&gt;Lab-NAT&lt;/b&gt; (internal switch) — 10.10.10.0/24&#10;Host vNIC: leased by dnsmasq (dynamic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="420" y="190" width="720" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="wsdc" value="&lt;b&gt;WS2025-DC1&lt;/b&gt; · 10.10.10.10&#10;&#10;MAC pinned 00:15:5D:0A:0A:0A&#10;(router1 reserves the IP)&#10;&#10;Windows Server 2025 Standard Eval&#10;Server Core · FFL = WinThreshold (2016)&#10;&#10;&lt;i&gt;lab.test&lt;/i&gt; forest root&#10;&#10;MSFT WS2025-2602 Security Baseline&#10;linked to OU=Domain Controllers&#10;(LDAP sign, SMB sign, Kerberos AES,&#10;Defender, VBS, Domain Security)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=center;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="445" y="270" width="330" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="sambadc" value="&lt;b&gt;samba-dc1&lt;/b&gt; · 10.10.10.20&#10;&#10;MAC pinned 00:15:5D:0A:0A:14&#10;&#10;Debian 13 Trixie (minimal)&#10;Samba 4.22.8 AD DC&#10;PowerShell 7.6 · chrony · hyperv-daemons&#10;&#10;Boots on DHCP → samba-sconfig&#10;converts to static post-configure.&#10;Joins lab.test as additional DC via&#10;&lt;code&gt;samba-sconfig join-dc&lt;/code&gt; (headless)&#10;or TUI menu.&#10;&#10;samba-sconfig at /usr/local/sbin/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;align=center;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="805" y="270" width="330" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="arrNet" value="Internet" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10" edge="1" parent="1" source="internet" target="extsw">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrMH" value="ssh nmadmin@server&#10;(key-based, PowerShell 7.6)" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10" edge="1" parent="1" source="mac" target="host">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrMR" value="ssh -J nmadmin@server hm@10.10.10.1" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10;dashed=1;strokeColor=#0066cc;strokeWidth=1.5" edge="1" parent="1" source="mac" target="router">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrMS" value="ssh -J nmadmin@server debadmin@10.10.10.20" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10;dashed=1;strokeColor=#0066cc;strokeWidth=1.5" edge="1" parent="1" source="mac" target="sambadc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrRouterExt" value="WAN (eth0)&#10;DHCP" style="endArrow=classic;startArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10" edge="1" parent="1" source="router" target="extsw">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrRouterInt" value="LAN (eth1)&#10;10.10.10.1" style="endArrow=classic;startArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10;strokeColor=#82b366;strokeWidth=1.5" edge="1" parent="1" source="router" target="intsw">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrWSInt" value="DHCP → .10" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10" edge="1" parent="1" source="intsw" target="wsdc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrSambaInt" value="DHCP → .20" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10" edge="1" parent="1" source="intsw" target="sambadc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrRep" value="AD replication (DRSUAPI RPC) · Kerberos · LDAP(S) · SMB · DNS&#10;&lt;i&gt;bidirectional after samba-sconfig join-dc:&#10;FL auto-detect, PTR auto-register, SYSVOL auto-seed&lt;/i&gt;" style="endArrow=classic;startArrow=classic;html=1;labelBackgroundColor=#ffffff;fontSize=10;strokeWidth=2;strokeColor=#b85450" edge="1" parent="1" source="wsdc" target="sambadc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="legendWrapper" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc" vertex="1" parent="1">
          <mxGeometry x="65" y="590" width="1070" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="legendTitle" value="Key changes vs v1 (isolated Lab-Internal 172.22.0.0/24)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="595" width="500" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="legendBody" value="• Lab-NAT switch (10.10.10.0/24) replaces Lab-Internal; no add/remove-NIC dance — VMs boot with Internet reachable&#10;• router1 Debian VM (cloud-init from NoCloud seed ISO) serves DHCP + DNS + NAT; mirrors a real office/home LAN&#10;• WS2025-DC1 + samba-dc1 get IPs via dnsmasq reservations keyed on Hyper-V static MACs — predictable addressing&#10;• samba-sconfig first-boot wizard: checks Internet, offers apt update/upgrade, prompts to pin the DHCP lease as static&#10;• lab/FirstLogon-PromoteToDC.ps1 now uses HKLM RunOnce to auto-fire Phase 2 after the promotion reboot (was broken in v1)&#10;• lab/Apply-SecurityBaseline.ps1 uses exact DisplayName match so Member Server GPO links (was hitting Credential Guard)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="80" y="612" width="1050" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="flowtitle" value="Test flow — run on clean golden-image revert" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="705" width="500" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="&lt;b&gt;T1 — Smoke&lt;/b&gt;&#10;&#10;DHCP lease OK&#10;Internet reachable&#10;samba-sconfig present&#10;pwsh 7.6 OK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="50" y="730" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="&lt;b&gt;T2 — Join WS2025&lt;/b&gt;&#10;&#10;samba-sconfig join-dc&#10;• FL probe = 2016&#10;• PTR auto-registered&#10;• chrony repointed&#10;• TLS cert with SAN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="300" y="730" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="&lt;b&gt;T3 — Repl + Functional&lt;/b&gt;&#10;&#10;showrepl 0/5 failures&#10;users round-trip&#10;GPO objects replicate&#10;SYSVOL seeded" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="550" y="730" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="&lt;b&gt;T4 — Baseline compliance&lt;/b&gt;&#10;&#10;LDAP sign · SMB sign&#10;Kerberos = strong&#10;LDAPS cert w/ SAN&#10;10y validity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="800" y="730" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="flowEdge1" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="t1" target="t2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="flowEdge2" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="t2" target="t3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="flowEdge3" style="endArrow=classic;html=1;strokeWidth=1.5" edge="1" parent="1" source="t3" target="t4">
