# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Private local coding-agent workspaces and settings.
.claude/
.codex/
.cursor/
.continue/
.aider*

# Scenario transcripts are local evidence. Keep distilled findings in
# test-results/*.md instead of committing raw run logs.
test-results/*.log

# Release artifacts (vhdx / qcow2 / vmdk / ova are multi-GB each).
# Reproducible from a deploy-master snapshot via lab/export-deploy-master.sh.
dist/

# Operator SSH public keys baked into the master image at build time —
# stay local to the builder's environment. The README inside is the
# only tracked file; the *.pub files vary per builder.
lab/keys/*
!lab/keys/README.md

# Backend / production credential files must never leave the builder's
# machine. Defensive entry — samba-addc-appliance doesn't currently
# carry creds, but the rule is shared across siblings (per
# dev-commons/STYLE.md §9) so an accidental copy of /etc/samba/secrets.tdb
# or any *creds* file doesn't slip in.
*creds*
!docs/**/*creds*
